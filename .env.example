TELEGRAM_BOT_TOKEN=put_your_bot_token_here

# Optional LLM layer. DeepSeek API is OpenAI-compatible.
LLM_ENABLED=auto
LLM_API_BASE=https://api.deepseek.com
LLM_MODEL=deepseek-chat
LLM_FALLBACK_MODELS=
LLM_API_KEY=put_your_deepseek_api_key_here
LLM_TIMEOUT_SECONDS=12

# Optional path for daily greeting memory.
GREETING_STATE_PATH=.state/daily_greetings.json

# Optional path for chat reply memory. The bot uses it as tone/context hints.
USER_MEMORY_PATH=.state/user_reply_memory.json
USER_MEMORY_MAX_ITEMS=120
