TELEGRAM_BOT_TOKEN=put_your_bot_token_here

# Optional LLM layer. OpenRouter's free router still requires a free API key.
LLM_ENABLED=auto
LLM_API_BASE=https://openrouter.ai/api/v1
LLM_MODEL=openrouter/free
LLM_API_KEY=put_your_openrouter_api_key_here
LLM_TIMEOUT_SECONDS=8

# Optional path for daily greeting memory.
GREETING_STATE_PATH=.state/daily_greetings.json
